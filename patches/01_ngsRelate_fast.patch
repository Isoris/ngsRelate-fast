+// ============================================================================
+// ngsRelate-fast: per-chromosome balanced-density downsampling
+// ----------------------------------------------------------------------------
+// Reduces the global site count to ~target_sites_per_gb per Gb of assembled
+// length, applied PER CHROMOSOME so density (sites/bp) is uniform across
+// chromosomes regardless of how many sites survived MAF/missingness filters.
+//
+// Inputs are mutated in place: gls, freq, and any parallel per-site arrays
+// produced by the file reader.
+//
+// Site IDs in BEAGLE are "chrom_pos" strings. We parse the chromosome out
+// by splitting on the LAST '_' (positions are always trailing integers).
+// ============================================================================
+
+#include <string>
+#include <unordered_map>
+
+struct ChromExtent {
+    long min_pos;
+    long max_pos;
+    int n_sites;
+};
+
+// Parse "chrom_pos" -> (chrom, pos). Splits on the last underscore.
+static int parse_site_id(const char *site_id, std::string &chrom_out, long &pos_out) {
+    const char *p = site_id + strlen(site_id) - 1;
+    while (p > site_id && *p != '_') p--;
+    if (p == site_id) return -1;
+    chrom_out.assign(site_id, p - site_id);
+    char *endp = NULL;
+    pos_out = strtol(p + 1, &endp, 10);
+    if (endp == p + 1) return -1;
+    return 0;
+}
+
+// Returns new nsites after downsampling. Caller is responsible for the
+// gls/freq arrays being reallocated to the returned size (we do it here).
+size_t downsample_sites_balanced(double ***gls_pp,
+                                 std::vector<double> *freq,
+                                 std::vector<char *> &site_ids,
+                                 size_t nsites_in,
+                                 int n_individuals) {
+    if (target_sites_per_gb <= 0) {
+        fprintf(stderr, "[ngsRelate-fast] -D 0: downsampling disabled, using all %zu sites\n", nsites_in);
+        return nsites_in;
+    }
+    if (nsites_in == 0) return 0;
+
+    // ---- Pass 1: per-chromosome extents and counts ----
+    std::unordered_map<std::string, ChromExtent> extents;
+    std::vector<std::string> chrom_of_site(nsites_in);
+    std::vector<long> pos_of_site(nsites_in);
+
+    for (size_t i = 0; i < nsites_in; i++) {
+        std::string c;
+        long pos;
+        if (parse_site_id(site_ids[i], c, pos) != 0) {
+            fprintf(stderr, "[ngsRelate-fast] WARN: cannot parse site id '%s', skipping downsampling\n", site_ids[i]);
+            return nsites_in;
+        }
+        chrom_of_site[i] = c;
+        pos_of_site[i] = pos;
+        auto it = extents.find(c);
+        if (it == extents.end()) {
+            ChromExtent e = {pos, pos, 1};
+            extents[c] = e;
+        } else {
+            if (pos < it->second.min_pos) it->second.min_pos = pos;
+            if (pos > it->second.max_pos) it->second.max_pos = pos;
+            it->second.n_sites++;
+        }
+    }
+
+    double sites_per_bp = (double)target_sites_per_gb / 1e9;
+    fprintf(stderr, "[ngsRelate-fast] Downsampling: target density %d sites/Gb (%.3e sites/bp)\n",
+            target_sites_per_gb, sites_per_bp);
+    fprintf(stderr, "[ngsRelate-fast] Detected %zu chromosome(s) in input\n", extents.size());
+
+    // ---- Compute per-chromosome stride ----
+    std::unordered_map<std::string, double> stride_of_chrom;
+    std::unordered_map<std::string, int> target_of_chrom;
+    long total_genome_bp = 0;
+    size_t total_target = 0;
+
+    for (auto &kv : extents) {
+        long L = kv.second.max_pos - kv.second.min_pos + 1;
+        total_genome_bp += L;
+        int n_target = (int)round(sites_per_bp * (double)L);
+        if (n_target < 1) n_target = 1;
+        if (n_target > kv.second.n_sites) n_target = kv.second.n_sites;
+        target_of_chrom[kv.first] = n_target;
+        stride_of_chrom[kv.first] = (double)kv.second.n_sites / (double)n_target;
+        total_target += n_target;
+        fprintf(stderr, "[ngsRelate-fast]   %s: %d sites in %.2f Mb -> keep %d (stride %.2f)\n",
+                kv.first.c_str(), kv.second.n_sites, L / 1e6,
+                n_target, stride_of_chrom[kv.first]);
+    }
+    fprintf(stderr, "[ngsRelate-fast] Total: %zu -> %zu sites (genome length %.3f Gb)\n",
+            nsites_in, total_target, total_genome_bp / 1e9);
+
+    // ---- Pass 2: pick sites by stride, per chromosome ----
+    std::unordered_map<std::string, int> seen_in_chrom;
+    std::unordered_map<std::string, double> next_pick_in_chrom;
+    for (auto &kv : extents) {
+        seen_in_chrom[kv.first] = 0;
+        next_pick_in_chrom[kv.first] = 0.0;
+    }
+
+    double **gls = *gls_pp;
+    double **gls_new = new double*[total_target];
+    std::vector<double> freq_new;
+    freq_new.reserve(total_target);
+    std::vector<char*> site_ids_new;
+    site_ids_new.reserve(total_target);
+    size_t k = 0;
+
+    for (size_t i = 0; i < nsites_in; i++) {
+        const std::string &c = chrom_of_site[i];
+        double next_pick = next_pick_in_chrom[c];
+        int seen = seen_in_chrom[c];
+        if ((double)seen >= next_pick) {
+            gls_new[k++] = gls[i];                        // transfer ownership
+            freq_new.push_back(freq->at(i));
+            site_ids_new.push_back(site_ids[i]);
+            next_pick_in_chrom[c] = next_pick + stride_of_chrom[c];
+        } else {
+            delete [] gls[i];                              // free unused row
+        }
+        seen_in_chrom[c] = seen + 1;
+    }
+
+    delete [] gls;
+    *gls_pp = gls_new;
+    freq->swap(freq_new);
+    site_ids.swap(site_ids_new);
+    fprintf(stderr, "[ngsRelate-fast] Downsampling complete: %zu sites retained\n", k);
+    return k;
+}
